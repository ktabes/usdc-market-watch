# Copy to .env for local development. Never commit .env.
NODE_ENV=development
DATABASE_URL=postgresql://market_watch:market_watch@localhost:5432/market_watch
HYPEREVM_RPC_URL=https://rpc.hyperlend.finance
HYPEREVM_ARCHIVE_RPC_URL=https://rpc.hyperlend.finance/archive
HYPEREVM_CHAIN_ID=999
CONFIRMATION_LAG=20
LOG_BLOCK_CHUNK_SIZE=50
LOG_LEVEL=info

# Optional: used by the real PostgreSQL integration smoke test.
# Falls back to DATABASE_URL when RUN_DATABASE_INTEGRATION_TESTS=true.
TEST_DATABASE_URL=postgresql://market_watch:market_watch@localhost:5432/market_watch_test
RUN_DATABASE_INTEGRATION_TESTS=false
RUN_NETWORK_INTEGRATION_TESTS=false
